{
  "name": "minitel-blocks-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Interface educative en blocs pour programmer un ESP32 qui pilote un Minitel.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:web": "npm run build && node scripts/serve-dist.cjs",
    "start": "electron .",
    "build": "tsc && vite build --configLoader runner",
    "preview": "npm run build && node scripts/serve-dist.cjs",
    "serve": "node scripts/serve-dist.cjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
