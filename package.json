{
  "name": "minitel-blocks-studio",
  "version": "0.0.5",
  "private": true,
  "description": "Interface éducative en blocs pour programmer un ESP32 qui pilote un Minitel.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:web": "npm run build && node scripts/serve-dist.cjs",
    "start": "electron .",
    "build": "tsc && vite build --configLoader runner",
    "preview": "npm run build && node scripts/serve-dist.cjs",
    "serve": "node scripts/serve-dist.cjs",
    "pack": "npm run build && npm run prepare:esp32 && electron-builder --dir --publish never",
    "dist:win": "npm run build && npm run prepare:esp32 && electron-builder --win nsis --publish never",
    "dist": "npm run dist:win",
    "prepare:esp32": "node scripts/prepare-esp32-toolchain.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  },
  "author": "fifou",
  "license": "Apache-2.0",
  "build": {
    "appId": "fr.fifou.minitel-blocks-studio",
    "productName": "Minitel Blocks Studio",
    "copyright": "Copyright © 2026 fifou",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "logo.png"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      },
      {
        "from": "logo.png",
        "to": "logo.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Minitel-Blocks-Studio-Setup-${version}.${ext}",
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Minitel Blocks Studio",
      "runAfterFinish": true,
      "license": "LICENSE",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GregVido",
        "repo": "Minitel-Blocks-Studio"
      }
    ]
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
